# Sayman — Environment variables (root)
# Lokal dev: bu dosyayı .env'e kopyala ve değerleri düzenle.

# --- Database ---------------------------------------------------------------
# Lokal: infra/docker-compose.yml içindeki postgres container (port 5434)
DATABASE_URL=postgres://sayman:sayman@localhost:5434/sayman
DIRECT_URL=postgres://sayman:sayman@localhost:5434/sayman

# --- API server -------------------------------------------------------------
# Port'lar diğer projelerle (Damga 5273, Lokma 5274/4200, Deploi 5276,
# Santral 5277, x-platform 5200/4250) çakışmayacak şekilde seçildi.
NODE_ENV=development
PORT=4300
CLIENT_URL=http://localhost:5278
LOG_LEVEL=debug

# --- Auth (Supabase — Faz B) -----------------------------------------------
# Lokal dev'de opsiyonel: yapılandırılmamışsa /v1/me ve login akışı 503 döner.
# Production'da Coolify env'lerinde ZORUNLU.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret (Supabase token verify dışında kullanılan iç işler için)
JWT_SECRET=CHANGE-ME-min-32-chars-long-random-secret

# --- Web (apps/web) ---------------------------------------------------------
VITE_API_URL=http://localhost:4300/v1
# Web Supabase Auth client için (Coolify'da Build Arguments olarak set):
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
