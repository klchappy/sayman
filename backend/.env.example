# --- Django ----------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.local
# Üret: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=CHANGE-ME-set-a-long-random-secret-here
DEBUG=1
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# --- Database (config.settings.local_pg veya production için) --------------
DB_NAME=muhasebe
DB_USER=muhasebe
DB_PASSWORD=CHANGE-ME
DB_HOST=127.0.0.1
DB_PORT=5432

# --- Deploy paths (production) ---------------------------------------------
DEPLOY_ROOT=/var/www/muhasebe-ops
PRIVATE_MEDIA_ROOT=/var/www/muhasebe-ops/private_media
DJANGO_LOG_DIR=/var/log/muhasebe-ops

# --- Security flags --------------------------------------------------------
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000

# --- E-posta (default kapalı / dummy backend) ------------------------------
DJANGO_EMAIL_BACKEND=django.core.mail.backends.dummy.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
