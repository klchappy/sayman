# --- Sayman — Multi-Tenant Muhasebe SaaS .gitignore ---

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
build/
dist/

# Virtualenv
venv/
.venv/
env/
ENV/

# Django
*.sqlite3
*.sqlite3-journal
db.sqlite3
db.sqlite3.bak
backend/db.sqlite3*
staticfiles/
backend/staticfiles/
backend/media/
backend/private_media/
media/
private_media/
local_settings.py

# Secrets
.env
.env.*
!.env.example
*.pem
*.key

# Logs
logs/
*.log
backend/logs/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
nosetests.xml
coverage.xml

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Backups
*.dump
*.tar.gz
*.bak
backups/
_local_backup/

# Build
node_modules/
*.lock

# Source data (kaynak Excel/RAR/PDF — repo dışı)
_source_data/
