{
  "name": "sayman",
  "version": "0.1.0",
  "private": true,
  "description": "Sayman — Multi-Tenant Muhasebe Operasyon Platformu",
  "scripts": {
    "dev": "pnpm -r --parallel --filter ./apps/* dev",
    "build": "pnpm -r --filter ./apps/* build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @sayman/db generate",
    "db:migrate": "pnpm --filter @sayman/db migrate",
    "db:seed": "pnpm --filter @sayman/db seed",
    "db:studio": "pnpm --filter @sayman/db studio",
    "smoke:prod:e2e": "node scripts/prod-smoke-e2e.mjs",
    "format": "prettier -w \"**/*.{ts,tsx,json,md}\""
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "pg": "^8.20.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "xlsx": "^0.18.5"
  }
}
