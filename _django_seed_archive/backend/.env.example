# --- Django ----------------------------------------------------------------
# Lokal dev (Docker Compose): config.settings.local_pg
DJANGO_SETTINGS_MODULE=config.settings.local_pg
# Üret: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=CHANGE-ME-set-a-long-random-secret-here
DEBUG=1
# Multi-tenant subdomain'leri için wildcard
ALLOWED_HOSTS=.localhost,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# --- Database (django-tenants postgresql_backend) --------------------------
# Docker Compose ortamında DB_HOST=db (compose service adı)
# Native PostgreSQL kurulumunda DB_HOST=127.0.0.1
DB_NAME=sayman_dev
DB_USER=sayman_user
DB_PASSWORD=sayman_pass
DB_HOST=db
DB_PORT=5432

# --- Deploy paths (production) ---------------------------------------------
DEPLOY_ROOT=/var/www/sayman
PRIVATE_MEDIA_ROOT=/var/www/sayman/private_media
DJANGO_LOG_DIR=/var/log/sayman

# --- Security flags --------------------------------------------------------
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000

# --- E-posta (default kapalı / dummy backend) ------------------------------
DJANGO_EMAIL_BACKEND=django.core.mail.backends.dummy.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
